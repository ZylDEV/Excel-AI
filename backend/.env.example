# === AI / LLM (BYOK - Bring Your Own Key) ===
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Choose default LLM provider: openai | gemini | openrouter | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# === Database ===
DATABASE_URL=sqlite:///./data/excel_genius.db

# === Server ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
